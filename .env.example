# FinGraph 환경 설정 (예시)
# 실제 값은 .env 에 작성. .env 는 git 추적 제외 (.gitignore).

# =============================================================
# LLM Provider (어댑터 패턴 — 한 줄로 백엔드 교체)
# =============================================================
LLM_PROVIDER=openai          # openai | anthropic | local
LLM_MODEL=gpt-4o
LLM_API_KEY=
LLM_TIMEOUT=120              # 초

# (선택) 용도별 모델 매핑 — PRD §5.3 / §7.5.2
LLM_MODEL_TRIAGE=gpt-4o-mini
LLM_MODEL_PLANNER=claude-sonnet-4-5
LLM_MODEL_SUPERVISOR=gpt-4o-mini
LLM_MODEL_RESEARCH=gpt-4o-mini
LLM_MODEL_GRAPH=claude-sonnet-4-5
LLM_MODEL_SQL=gpt-4o-mini
LLM_MODEL_CALCULATOR=gpt-4o-mini
LLM_MODEL_VALIDATOR=gpt-4o-mini
LLM_MODEL_SYNTHESIZER=claude-sonnet-4-5
LLM_MODEL_JUDGE=gpt-4o       # 평가 일관성

# 로컬 LLM (vLLM/Ollama) — LLM_PROVIDER=local 일 때 사용
LOCAL_LLM_BASE_URL=http://localhost:8000/v1

# =============================================================
# 임베딩 (BGE-M3 자체 호스팅 — TEI 컨테이너)
# =============================================================
EMBEDDING_URL=http://localhost:8080
RERANKER_URL=http://localhost:8081
EMBEDDING_DIM=1024           # BGE-M3 기본

# =============================================================
# DB 연결 (docker-compose 내부 서비스명)
# =============================================================
# Neo4j (그래프)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fingraph_dev

# PostgreSQL (재무 수치, 마스터, 평가 QA, LangGraph 체크포인트)
POSTGRES_DSN=postgresql://fingraph:fingraph_dev@postgres:5432/fingraph

# Qdrant (벡터)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=              # 로컬 dev 환경에선 비워둠

# =============================================================
# 데이터 소스 API
# =============================================================
# DART Open API — opendart.fss.or.kr 무료 가입
DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api

# 한국은행 ECOS API — ecos.bok.or.kr 무료 가입
ECOS_API_KEY=
ECOS_BASE_URL=https://ecos.bok.or.kr/api

# KRX는 키 불필요 (정보데이터시스템 CSV 다운로드)
KRX_BASE_URL=http://data.krx.co.kr

# =============================================================
# 수집 범위
# =============================================================
INGEST_TICKERS=KOSPI200,KOSDAQ100
INGEST_YEARS_BACK=3
INGEST_RATE_LIMIT_PER_SEC=10       # DART 호출 속도 가드
INGEST_RAW_DIR=data/raw
INGEST_PROCESSED_DIR=data/processed

# =============================================================
# 에이전트 운영
# =============================================================
AGENT_MAX_REPLAN=2                  # PRD §7.5.5
AGENT_QUERY_BUDGET_SEC=40
AGENT_MAX_ANSWER_LEN=5000

# =============================================================
# Tracing / Observability
# =============================================================
TRACE_BACKEND=                      # langfuse | langsmith | (빈값=off)
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fingraph

# =============================================================
# 운영
# =============================================================
APP_ENV=local                       # local | server | production
LOG_LEVEL=INFO
